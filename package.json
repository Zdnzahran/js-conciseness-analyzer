  "description": "Analyze your JavaScript code for conciseness and complexity using Halstead Metrics.",
  "version": "1.0.2",
  "publisher": "SahabatSapi",
  "icon": "icon.ico",
  "scripts": {
    "test": "mocha test/**/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Zdnzahran/js-conciseness-analyzer.git"
  },
  "bugs": {
    "url": "https://github.com/Zdnzahran/js-conciseness-analyzer.git"
  },
  "homepage": "https://github.com/Zdnzahran/js-conciseness-analyzer.git",
  "engines": {
    "vscode": "^1.0.0"
  },
  "main": "./src/extension.js",
  "activationEvents": [
    "onCommand:jsAnalyzer.openMainMenu"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jsAnalyzer.openMainMenu",
        "title": "JS Conciseness: Open Main Menu"
      }
    ]
  },
  "dependencies": {
    "acorn": "^8.16.0"
  },
  "devDependencies": {
    "mocha": "^11.7.5"
  }
